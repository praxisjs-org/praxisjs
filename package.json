{
  "name": "praxisjs",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:dev": "pnpm --filter @praxisjs/docs docs:dev",
    "docs:build": "pnpm --filter @praxisjs/docs docs:build",
    "docs:preview": "pnpm --filter @praxisjs/docs docs:preview",
    "prepare": "husky",
    "build:foundation": "pnpm --filter './packages/foundation/**' build",
    "build:features": "pnpm --filter './packages/features/**' build",
    "build:dx": "pnpm --filter './packages/dx/**' build",
    "build:utils": "pnpm --filter './packages/utils/**' build",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-template-versions.mjs",
    "release": "changeset publish",
    "sync-templates": "node scripts/sync-template-versions.mjs"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": "eslint --fix"
  },
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.2",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.0"
  }
}
