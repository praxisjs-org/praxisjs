{
  "name": "create-verbose",
  "version": "0.1.0",
  "description": "Scaffold a new Verbose framework project",
  "type": "module",
  "bin": {
    "create-verbose": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@verbose/composables": "workspace:*",
    "@verbose/concurrent": "workspace:*",
    "@verbose/core": "workspace:*",
    "@verbose/decorators": "workspace:*",
    "@verbose/devtools": "workspace:*",
    "@verbose/di": "workspace:*",
    "@verbose/jsx": "workspace:*",
    "@verbose/router": "workspace:*",
    "@verbose/runtime": "workspace:*",
    "@verbose/store": "workspace:*",
    "tsdown": "0.20.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "verbose",
    "create-verbose",
    "scaffold",
    "frontend",
    "framework"
  ],
  "packageManager": "pnpm@10.30.2"
}
