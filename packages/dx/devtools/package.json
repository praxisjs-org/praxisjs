{
  "name": "@praxisjs/devtools",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "generate:css": "unocss \"src/**/*.{ts,tsx}\" -o assets/uno.generated.css",
    "build": "vite build",
    "prebuild": "pnpm run generate:css",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@praxisjs/core": "workspace:*",
    "@praxisjs/decorators": "workspace:*",
    "@praxisjs/jsx": "workspace:*",
    "@praxisjs/runtime": "workspace:*",
    "@praxisjs/shared": "workspace:*",
    "@unocss/reset": "^66.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@unocss/cli": "^66.6.2",
    "@unocss/preset-wind3": "^66.6.6",
    "typescript": "^5.9.3",
    "unocss": "^66.6.6",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "packageManager": "pnpm@10.30.2"
}
